# ================================================
# نموذج المتغيرات البيئية | Environment Variables
# انسخ هذا الملف باسم .env وعدّل القيم
# Copy this file to .env and update the values
# ================================================

# قاعدة البيانات | Database
DATABASE_URL=postgres://hruser:hrpassword@localhost:5432/hr_db

# الجلسة | Session
SESSION_SECRET=change_this_to_a_long_random_string_minimum_32_chars

# الخادم | Server
PORT=5001
NODE_ENV=production

# الكوكيز | Cookies
# true في بيئة HTTPS، false في بيئة HTTP محلية
COOKIE_SECURE=false
